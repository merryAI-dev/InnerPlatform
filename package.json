{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy:prod:safe": "node ./deploy-prod-align.mjs",
    "dev": "vite",
    "dev:local": "VITE_DEV_AUTH_HARNESS_ENABLED=true VITE_DEMO_LOGIN_ENABLED=true VITE_FIREBASE_AUTH_ENABLED=false VITE_FIRESTORE_CORE_ENABLED=false vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config playwright.harness.config.mjs",
    "test:settlement:integration": "bash scripts/test_settlement_product_completeness_integration.sh",
    "bff:dev": "node server/bff/server.mjs",
    "bff:seed:demo": "node scripts/bff_seed_demo_data.mjs",
    "bff:test:integration": "bash scripts/test_bff_integration.sh",
    "bff:cleanup:idempotency": "node server/bff/cleanup_idempotency.mjs",
    "bff:outbox:worker": "node server/bff/outbox-worker.mjs",
    "bff:work-queue:worker": "node server/bff/work-queue-worker.mjs",
    "bff:deploy:cloud-run": "bash scripts/deploy_bff_cloud_run.sh",
    "firebase:bootstrap": "bash scripts/firebase_bootstrap.sh",
    "firebase:login": "npx firebase-tools login --no-localhost",
    "firebase:login:daemon:start": "node scripts/firebase_login_daemon.mjs start --open",
    "firebase:login:daemon:status": "node scripts/firebase_login_daemon.mjs status",
    "firebase:login:daemon:submit": "node scripts/firebase_login_daemon.mjs submit",
    "firebase:whoami": "npx firebase-tools login:list",
    "firebase:open:google-auth": "bash scripts/firebase_open_google_auth_provider.sh",
    "firebase:deploy:firestore": "npx firebase-tools deploy --only firestore:rules,firestore:indexes",
    "firebase:deploy:indexes": "bash scripts/firebase_deploy_indexes.sh",
    "firebase:autosetup": "bash scripts/firebase_autosetup.sh",
    "firebase:fill-env": "bash scripts/firebase_fill_env_from_config.sh",
    "firebase:emulators:prepare": "bash scripts/firebase_emulator_bootstrap.sh",
    "firebase:emulators:start": "bash scripts/firebase_emulator_bootstrap.sh --start",
    "qa:feedback:ingest": "npx tsx scripts/ingest_qa_feedback_tracker.ts",
    "phase:preflight": "npx tsx scripts/phase_preflight_qa.ts",
    "phase1:portal:validation-gate": "npx tsx scripts/phase1_portal_validation_gate.ts",
    "phase1:extract:usage-ledger": "npx tsx scripts/extract_usage_ledger_phase1_fixture.ts",
    "rust:settlement:build": "cargo build --quiet --manifest-path rust/spreadsheet-calculation-core/Cargo.toml",
    "rust:settlement:test": "cargo test --manifest-path rust/spreadsheet-calculation-core/Cargo.toml",
    "workbook:extract:formulas": "npx tsx scripts/extract_workbook_formula_inventory.ts",
    "firestore:live-cutover": "npx tsx scripts/firestore_live_cutover.ts",
    "firestore:backup:schedule": "bash scripts/firestore_backup_schedule.sh",
    "firestore:backup:rehearsal": "bash scripts/firestore_backup_rehearsal.sh",
    "monitoring:setup:alerts": "bash scripts/setup_monitoring_alerts.sh",
    "monitoring:setup:slack": "bash scripts/setup_monitoring_slack_channel.sh",
    "monitoring:setup:uptime": "bash scripts/setup_monitoring_uptime_checks.sh",
    "pii:rotate": "node scripts/pii_rotate_fields.mjs",
    "pii:setup:vercel": "bash scripts/pii_setup_vercel_local.sh",
    "policy:verify": "node scripts/verify_rbac_policy.mjs",
    "etl:build:staging-json": "npx tsx scripts/etl/build-staging-json.ts",
    "etl:sync:staging": "npx tsx scripts/etl/sync-staging-to-firestore.ts",
