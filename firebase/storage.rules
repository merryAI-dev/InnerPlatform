rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ── 테넌트 스코프 스토리지 경로: orgs/{orgId}/** ──
    // Firestore와 달리 Storage에서는 Firestore 멤버십 조회 불가.
    // 최소 보안 레이어: Firebase 로그인 + @mysc.co.kr 이메일 도메인 확인.
    match /orgs/{orgId}/{allPaths=**} {
      allow read: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@mysc\\.co\\.kr$');
      allow write: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@mysc\\.co\\.kr$');
    }

    // 그 외 경로: 모두 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
