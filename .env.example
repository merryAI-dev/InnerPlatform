# Firebase runtime config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Org scope
VITE_DEFAULT_ORG_ID=mysc
VITE_TENANT_ISOLATION_STRICT=true

# Feature flags
VITE_FIREBASE_USE_ENV_CONFIG=true
VITE_FIREBASE_AUTH_ENABLED=true
VITE_FIRESTORE_CORE_ENABLED=true
VITE_FIREBASE_USE_EMULATORS=false
VITE_FIREBASE_USE_FIRESTORE_EMULATOR=false
VITE_FIREBASE_USE_AUTH_EMULATOR=false
VITE_FIREBASE_USE_STORAGE_EMULATOR=false
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_FIRESTORE_EMULATOR_PORT=8080
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
VITE_FIREBASE_STORAGE_EMULATOR_PORT=9199
VITE_PLATFORM_API_ENABLED=false
VITE_PLATFORM_API_BASE_URL=http://127.0.0.1:8787
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# Optional fixed login/testing hosts for Firebase Auth on Vercel previews.
# Use exact hosts or full URLs, comma-separated. Random commit preview URLs should not be listed here.
VITE_FIREBASE_AUTH_ALLOWED_HOSTS=
# Optional fixed preview URL to open when login is blocked on a random Vercel preview.
VITE_FIREBASE_AUTH_FALLBACK_URL=
VITE_DEV_AUTH_HARNESS_ENABLED=false

# Demo login (disabled by default; set to true for local development only)
VITE_DEMO_LOGIN_ENABLED=false

# Bootstrap (client-side)
# Comma-separated email list. These emails will automatically get admin role and cannot register via portal.
VITE_BOOTSTRAP_ADMIN_EMAILS=ai@mysc.co.kr

# BFF runtime auth (server-side env)
# headers | firebase_optional | firebase_required
BFF_AUTH_MODE=headers
BFF_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Secret for internal worker endpoints (/api/internal/workers/*).
# For Vercel Cron, you can set CRON_SECRET and omit BFF_WORKER_SECRET.
BFF_WORKER_SECRET=
# Firebase Admin credentials for server runtime (pick one):
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}'
# FIREBASE_SERVICE_ACCOUNT_BASE64=
# Optional dedicated Drive service account (falls back to Firebase service account when omitted):
# GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=/absolute/path/to/drive-service-account.json
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}'
# GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=
# Shared Drive evidence automation:
# GOOGLE_DRIVE_SHARED_DRIVE_ID=
# GOOGLE_DRIVE_EVIDENCE_ROOT_FOLDER_ID=
# Internal client error -> Slack forwarding (server-side, optional)
# Recommended: Slack Incoming Webhook URL
SLACK_ALERT_WEBHOOK_URL=
# Alternative delivery via Slack Bot API
SLACK_ALERT_BOT_TOKEN=
SLACK_ALERT_CHANNEL_ID=
# info | warning | error | fatal
CLIENT_ERROR_SLACK_MIN_LEVEL=fatal
# BFF client error worker tuning
# BFF_CLIENT_ERROR_SLACK_BATCH=20
# BFF_CLIENT_ERROR_SLACK_MAX_ATTEMPTS=5

# Claude API (server-side, for Guide Q&A chatbot)
ANTHROPIC_API_KEY=

# Optional relation/pipeline tuning (server-side)
# RELATION_RULES_PATH=policies/relation-rules.json
# BFF_WORK_QUEUE_BATCH=100
